# LexisCo Backend Environment Variables
# Copy this file to .env and fill in your values

# === LLM ===
GROQ_API_KEY=your_groq_api_key_here

# === Database (Supabase) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# === Vector Database ===
VECTOR_DB=faiss        # Options: faiss, pinecone
PINECONE_API_KEY=      # Only if using Pinecone
PINECONE_ENV=          # Only if using Pinecone

# === App Config ===
APP_ENV=development    # development | production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# === Auth (if using JWT) ===
SECRET_KEY=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === Notification Gateways ===
# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMS (Indian - Fast2SMS/MSG91)
FAST2SMS_API_KEY=

# Email (Resend)
RESEND_API_KEY=
MAIL_FROM=noreply@lexisco.com

# Email (Free SMTP / Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                           # Your Gmail address
SMTP_PASSWORD=                       # Your 16-character Gmail App Password
